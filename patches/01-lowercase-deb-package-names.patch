diff --git a/scripts/package/mkdebian b/scripts/package/mkdebian
index d4b007b38a47..7a414ee1e797 100755
--- a/scripts/package/mkdebian
+++ b/scripts/package/mkdebian
@@ -172,6 +172,11 @@ else
 	packagename=linux-image
 fi
 
+# Debian package names must be lowercase; KERNELRELEASE may contain uppercase
+# letters (e.g. WSL2) that are required for kernel identification at runtime,
+# so lowercase only the portion used in package names.
+packagerelease=$(echo "${KERNELRELEASE}" | tr 'A-Z' 'a-z')
+
